---
import Layout from '../layouts/Layout.astro';
---

<Layout title="关于我们" description="天津大学视觉智能实验室简介">
  <!-- Header -->
  <div class="bg-gradient-to-br from-tju-red to-red-900 text-white py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl lg:text-5xl font-bold mb-4">关于我们</h1>
      <p class="text-xl text-red-100">About ViL</p>
    </div>
  </div>

  <!-- Content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid lg:grid-cols-3 gap-12">
      <!-- Main Content -->
      <div class="lg:col-span-2 space-y-8">
        <section class="prose prose-lg max-w-none">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">实验室简介</h2>
          <p class="text-gray-600 leading-relaxed">
            视觉智能实验室（Visual Intelligence Lab，简称 ViL）是天津大学智能与计算学部下属的研究实验室，
            致力于计算机视觉、视频分析、医学影像处理等相关领域的研究及应用工作。
          </p>
          <p class="text-gray-600 leading-relaxed mt-4">
            本实验室也是"文物本体表面监测与分析研究"国家文物局重点科研基地核心技术团队，
            是国内首个聚焦文物本体表面状态精密监测和分析问题、从事相关理论方法研究与应用推广的团队。
          </p>
        </section>

        <section>
          <h2 class="text-2xl font-bold text-gray-900 mb-6">研究特色</h2>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-gray-50 rounded-lg p-6">
              <div class="w-12 h-12 bg-red-100 rounded-lg flex items-center justify-center mb-4">
                <svg class="w-6 h-6 text-tju-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <h3 class="font-semibold text-gray-900 mb-2">理论与实践结合</h3>
              <p class="text-gray-600 text-sm">既关注前沿理论研究，也重视实际应用落地</p>
            </div>
            <div class="bg-gray-50 rounded-lg p-6">
              <div class="w-12 h-12 bg-red-100 rounded-lg flex items-center justify-center mb-4">
                <svg class="w-6 h-6 text-tju-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
                </svg>
              </div>
              <h3 class="font-semibold text-gray-900 mb-2">产学研合作</h3>
              <p class="text-gray-600 text-sm">与医院、博物馆等实际应用场景深度合作</p>
            </div>
            <div class="bg-gray-50 rounded-lg p-6">
              <div class="w-12 h-12 bg-red-100 rounded-lg flex items-center justify-center mb-4">
                <svg class="w-6 h-6 text-tju-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
                </svg>
              </div>
              <h3 class="font-semibold text-gray-900 mb-2">团队协作</h3>
              <p class="text-gray-600 text-sm">多学科交叉，鼓励团队协作与创新</p>
            </div>
            <div class="bg-gray-50 rounded-lg p-6">
              <div class="w-12 h-12 bg-red-100 rounded-lg flex items-center justify-center mb-4">
                <svg class="w-6 h-6 text-tju-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <h3 class="font-semibold text-gray-900 mb-2">国际视野</h3>
              <p class="text-gray-600 text-sm">积极参与国际学术交流与合作</p>
            </div>
          </div>
        </section>
      </div>

      <!-- Sidebar -->
      <div class="space-y-6">
        <div class="bg-gray-50 rounded-xl p-6">
          <h3 class="font-semibold text-gray-900 mb-4">联系我们</h3>
          <ul class="space-y-3 text-sm">
            <li class="flex items-start space-x-3">
              <svg class="w-5 h-5 text-tju-red mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <span class="text-gray-600">天津大学北洋园校区55教学楼</span>
            </li>
            <li class="flex items-start space-x-3">
              <svg class="w-5 h-5 text-tju-red mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              <a href="mailto:wfeng@ieee.org" class="text-gray-600 hover:text-tju-red">wfeng@ieee.org</a>
            </li>
            <li class="flex items-start space-x-3">
              <svg class="w-5 h-5 text-tju-red mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064"/>
              </svg>
              <span class="text-gray-600">邮编：300350</span>
            </li>
          </ul>
        </div>

        <div class="bg-gradient-to-br from-tju-red to-red-800 rounded-xl p-6 text-white">
          <h3 class="font-semibold mb-2">加入实验室</h3>
          <p class="text-red-100 text-sm mb-4">我们长期招聘博士后、博士、硕士研究生及科研助理</p>
          <a href="/join" class="inline-flex items-center text-sm font-medium hover:underline">
            了解更多
            <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>
