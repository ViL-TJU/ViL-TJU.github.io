---
import Layout from '../layouts/Layout.astro';
---

<Layout title="学术成果" description="视觉智能实验室学术成果">
  <div class="bg-gradient-to-br from-tju-red to-red-900 text-white py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl lg:text-5xl font-bold mb-4">学术成果</h1>
      <p class="text-xl text-red-100">Publications</p>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center">
      <p class="text-gray-600">实验室已发表论文100余篇，部分代表性成果正在整理中...</p>
      <p class="text-gray-500 mt-4">如需获取完整论文列表，请访问 <a href="http://www.tjuvil.net/qeihuan.aspx?ClassID=54" class="text-tju-red hover:underline" target="_blank">原网站</a></p>
    </div>
  </div>
</Layout>
