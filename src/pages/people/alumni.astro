---
import Layout from '../../layouts/Layout.astro';

interface Alumni {
  name: string;
  classYear?: string;
  destination: string;
  role: string;
  sector: string;
  image: string;
}

const phdAlumni: Alumni[] = [
  { name: '刘烨', classYear: '2017级', destination: '临沂大学', role: '教师', sector: 'academia', image: '/images/20240619173800.png' },
  { name: '王旭之', classYear: '2018级', destination: '天津师范大学', role: '教师', sector: 'academia', image: '/images/20240619173400.jpg' },
  { name: '吕凡', classYear: '2018级', destination: '中科院自动化所', role: '博士后', sector: 'academia', image: '/images/20230830095430.png' },
  { name: '边存灵', classYear: '2019级', destination: '中国海洋大学', role: '教师', sector: 'academia', image: '/images/20240619174359.jpg' },
  { name: '陈峙灏', classYear: '2019级', destination: '荣耀终端有限公司', role: '媒体算法高级工程师', sector: 'industry', image: '/images/20240608180658.jpg' },
  { name: '韩瑞泽', classYear: '2019级', destination: '深圳先进研究院', role: 'Researcher', sector: 'academia', image: '/images/20240601165337.png' },
];

const masterAlumni2021: Alumni[] = [
  { name: '马恩慧', destination: '西湖大学', role: '博士', sector: 'academia', image: '/images/20240711234134.jpg' },
  { name: '张家琪', destination: '美团', role: '策略产品经理', sector: 'industry', image: '/images/20240608183011.jpg' },
  { name: '崔晓', destination: '腾讯IEG天美L1工作室', role: '游戏客户端开发', sector: 'industry', image: '/images/20240608182922.jpg' },
  { name: '薛森华', destination: '腾讯', role: '游戏开发工程师', sector: 'industry', image: '/images/20240608182833.jpg' },
  { name: '李炜骐', destination: '中国农业银行研发中心', role: '研发工程师', sector: 'industry', image: '/images/20240608182709.jpg' },
  { name: '陈浩然', destination: '奥迪一汽新能源', role: '智能制造工程师', sector: 'industry', image: '/images/20240608182433.jpg' },
  { name: '王飞凡', destination: '联想研究院', role: '算法工程师', sector: 'industry', image: '/images/20240608182334.jpg' },
];

const masterAlumni2020: Alumni[] = [
  { name: '颜昊旻', destination: '阿里巴巴', role: '后端开发工程师', sector: 'industry', image: '/images/20240608182104.jpg' },
  { name: '申佳', destination: '香港理工大学', role: '研究助理', sector: 'academia', image: '/images/20240608181924.jpg' },
  { name: '史鹏', destination: '渤海银行', role: '软件开发工程师', sector: 'industry', image: '/images/20240608181817.jpg' },
  { name: '孙晴', destination: '商汤', role: '算法研究员', sector: 'industry', image: '/images/20240608181716.jpg' },
  { name: '马昊东', destination: '工商银行数据中心', role: '科技菁英', sector: 'industry', image: '/images/20240608181628.jpg' },
  { name: '肖业凡', destination: '北京小川科技', role: '图像算法工程师', sector: 'industry', image: '/images/20240608181538.jpg' },
  { name: '王明迁', destination: '理想汽车', role: '自动驾驶算法工程师', sector: 'industry', image: '/images/20240608181447.jpg' },
  { name: '阴立强', destination: '中国航空工业雷华研究所', role: '系统管理软件设计', sector: 'industry', image: '/images/20240608181401.jpg' },
  { name: '邢兆虎', destination: '香港科技大学（广州）', role: '博士', sector: 'academia', image: '/images/20240608181248.jpg' },
  { name: '孟繁博', destination: '中国农业发展银行', role: '软件开发工程师', sector: 'industry', image: '/images/20240608180954.jpg' },
];

const allAlumni = [...phdAlumni, ...masterAlumni2021, ...masterAlumni2020];
const totalAlumni = allAlumni.length;
const academiaCount = allAlumni.filter(a => a.sector === 'academia').length;
const industryCount = allAlumni.filter(a => a.sector === 'industry').length;
const academiaPercent = Math.round((academiaCount / totalAlumni) * 100);
const industryPercent = Math.round((industryCount / totalAlumni) * 100);
---

<Layout title="毕业学生" description="视觉智能实验室毕业学生">
  <!-- Header -->
  <div class="bg-gradient-to-br from-tju-red to-red-900 text-white py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl lg:text-5xl font-bold mb-4">毕业学生</h1>
      <p class="text-xl text-red-100">Alumni</p>
    </div>
  </div>

  <!-- Tab Navigation -->
  <div class="border-b border-gray-200 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex space-x-8">
        <a href="/people" class="border-b-2 border-transparent py-4 text-sm font-medium text-gray-500 hover:text-gray-700">所有成员</a>
        <a href="/people/faculty" class="border-b-2 border-transparent py-4 text-sm font-medium text-gray-500 hover:text-gray-700">教师</a>
        <a href="/people/students" class="border-b-2 border-transparent py-4 text-sm font-medium text-gray-500 hover:text-gray-700">在读学生</a>
        <a href="/people/alumni" class="border-b-2 border-tju-red py-4 text-sm font-medium text-tju-red">毕业学生</a>
      </nav>
    </div>
  </div>

  <!-- Stats -->
  <div class="bg-gray-50 border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        <div class="bg-white rounded-xl p-6 shadow-sm text-center">
          <p class="text-3xl font-bold text-tju-red">{totalAlumni}</p>
          <p class="text-sm text-gray-500 mt-1">毕业生总数</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm text-center">
          <p class="text-3xl font-bold text-blue-600">{academiaCount}<span class="text-lg font-normal text-gray-400 ml-1">({academiaPercent}%)</span></p>
          <p class="text-sm text-gray-500 mt-1">高校/科研院所</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm text-center">
          <p class="text-3xl font-bold text-emerald-600">{industryCount}<span class="text-lg font-normal text-gray-400 ml-1">({industryPercent}%)</span></p>
          <p class="text-sm text-gray-500 mt-1">企业/工业界</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

    <!-- PhD Alumni -->
    <section class="mb-16">
      <div class="flex items-center gap-3 mb-8">
        <div class="w-1.5 h-8 bg-tju-red rounded-full"></div>
        <h2 class="text-2xl font-bold text-gray-900">博士毕业生</h2>
        <span class="text-sm text-gray-500 bg-gray-100 px-3 py-1 rounded-full">{phdAlumni.length} 人</span>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {phdAlumni.map((person) => (
          <div class="bg-white border border-gray-200 rounded-xl p-5 hover:shadow-md transition-shadow">
            <div class="flex items-start gap-4">
              <img
                src={person.image}
                alt={person.name}
                class="w-14 h-14 rounded-full object-cover shrink-0 border-2 border-gray-100"
              />
              <div class="min-w-0">
                <div class="flex items-center gap-2">
                  <h3 class="font-semibold text-gray-900">{person.name}</h3>
                  <span class="text-xs text-gray-400">{person.classYear}</span>
                </div>
                <p class="text-sm text-gray-600 mt-1">{person.destination}</p>
                <p class="text-sm text-gray-500">{person.role}</p>
                <span class={`inline-block mt-2 text-xs px-2 py-0.5 rounded-full ${person.sector === 'academia' ? 'bg-blue-50 text-blue-700' : 'bg-emerald-50 text-emerald-700'}`}>
                  {person.sector === 'academia' ? '学术界' : '工业界'}
                </span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Master Alumni -->
    <section>
      <div class="flex items-center gap-3 mb-8">
        <div class="w-1.5 h-8 bg-tju-red rounded-full"></div>
        <h2 class="text-2xl font-bold text-gray-900">硕士毕业生</h2>
        <span class="text-sm text-gray-500 bg-gray-100 px-3 py-1 rounded-full">{masterAlumni2021.length + masterAlumni2020.length} 人</span>
      </div>

      <!-- Class of 2021 -->
      <div class="mb-10">
        <h3 class="text-lg font-semibold text-gray-700 mb-4 flex items-center gap-2">
          <span class="w-2 h-2 bg-tju-red rounded-full"></span>
          2021届 <span class="text-sm font-normal text-gray-400">({masterAlumni2021.length} 人)</span>
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {masterAlumni2021.map((person) => (
            <div class="bg-white border border-gray-200 rounded-xl p-5 hover:shadow-md transition-shadow">
              <div class="flex items-start gap-4">
                <img
                  src={person.image}
                  alt={person.name}
                  class="w-14 h-14 rounded-full object-cover shrink-0 border-2 border-gray-100"
                />
                <div class="min-w-0">
                  <h3 class="font-semibold text-gray-900">{person.name}</h3>
                  <p class="text-sm text-gray-600 mt-1">{person.destination}</p>
                  <p class="text-sm text-gray-500">{person.role}</p>
                  <span class={`inline-block mt-2 text-xs px-2 py-0.5 rounded-full ${person.sector === 'academia' ? 'bg-blue-50 text-blue-700' : 'bg-emerald-50 text-emerald-700'}`}>
                    {person.sector === 'academia' ? '学术界' : '工业界'}
                  </span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Class of 2020 -->
      <div>
        <h3 class="text-lg font-semibold text-gray-700 mb-4 flex items-center gap-2">
          <span class="w-2 h-2 bg-tju-red rounded-full"></span>
          2020届 <span class="text-sm font-normal text-gray-400">({masterAlumni2020.length} 人)</span>
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {masterAlumni2020.map((person) => (
            <div class="bg-white border border-gray-200 rounded-xl p-5 hover:shadow-md transition-shadow">
              <div class="flex items-start gap-4">
                <img
                  src={person.image}
                  alt={person.name}
                  class="w-14 h-14 rounded-full object-cover shrink-0 border-2 border-gray-100"
                />
                <div class="min-w-0">
                  <h3 class="font-semibold text-gray-900">{person.name}</h3>
                  <p class="text-sm text-gray-600 mt-1">{person.destination}</p>
                  <p class="text-sm text-gray-500">{person.role}</p>
                  <span class={`inline-block mt-2 text-xs px-2 py-0.5 rounded-full ${person.sector === 'academia' ? 'bg-blue-50 text-blue-700' : 'bg-emerald-50 text-emerald-700'}`}>
                    {person.sector === 'academia' ? '学术界' : '工业界'}
                  </span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

  </div>
</Layout>
