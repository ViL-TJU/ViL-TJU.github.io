function groupByGrade(students: Student[]): Record<string, Student[]> {
  const groups: Record<string, Student[]> = {};
  for (const s of students) {
    if (!groups[s.grade]) groups[s.grade] = [];
    groups[s.grade].push(s);
  }
  return groups;
}

const phdGroups = groupByGrade(phdStudents);
const masterGroups = groupByGrade(masterStudents);
const phdGrades = Object.keys(phdGroups).sort();
const masterGrades = Object.keys(masterGroups).sort();
---

<Layout title="在读学生" description="视觉智能实验室在读学生">
  <!-- Header -->
  <div class="bg-gradient-to-br from-tju-red to-red-900 text-white py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl lg:text-5xl font-bold mb-4">在读学生</h1>
      <p class="text-xl text-red-100">Current Students</p>
    </div>
  </div>

  <!-- Navigation Tabs -->
  <div class="border-b border-gray-200 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex space-x-8">
        <a href="/people" class="border-b-2 border-transparent py-4 text-sm font-medium text-gray-500 hover:text-gray-700">所有成员</a>
        <a href="/people/faculty" class="border-b-2 border-transparent py-4 text-sm font-medium text-gray-500 hover:text-gray-700">教师</a>
        <a href="/people/students" class="border-b-2 border-tju-red py-4 text-sm font-medium text-tju-red">在读学生</a>
        <a href="/people/alumni" class="border-b-2 border-transparent py-4 text-sm font-medium text-gray-500 hover:text-gray-700">毕业学生</a>
      </nav>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <!-- PhD Students -->
    <section>
      <div class="flex items-center gap-3 mb-8">
        <h2 class="text-2xl font-bold text-gray-900">博士研究生</h2>
        <span class="px-3 py-1 bg-red-100 text-tju-red text-sm font-medium rounded-full">{phdStudents.length} 人</span>
      </div>

      {phdGrades.map((grade) => (
        <div class="mb-10">
          <h3 class="text-lg font-semibold text-gray-700 mb-4 border-l-4 border-tju-red pl-3">{grade}</h3>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
            {phdGroups[grade].map((student) => (
              <div class="bg-white rounded-lg border border-gray-200 p-4 hover:shadow-md transition-shadow flex items-start gap-4">
                <img
                  src={student.image}
                  alt={student.name}
                  class="w-14 h-14 rounded-full object-cover shrink-0 border-2 border-gray-100"
                />
                <div class="min-w-0">
                  <h4 class="font-semibold text-gray-900">{student.name}</h4>
                  <p class="text-xs text-gray-500 mt-0.5">{student.grade}</p>
                  <p class="text-sm text-gray-600 mt-1 leading-snug">{student.research}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </section>

    <!-- Divider -->
    <hr class="border-gray-200" />

    <!-- Master Students -->
    <section>
      <div class="flex items-center gap-3 mb-8">
        <h2 class="text-2xl font-bold text-gray-900">硕士研究生</h2>
        <span class="px-3 py-1 bg-red-100 text-tju-red text-sm font-medium rounded-full">{masterStudents.length} 人</span>
      </div>

      {masterGrades.map((grade) => (
        <div class="mb-10">
          <h3 class="text-lg font-semibold text-gray-700 mb-4 border-l-4 border-tju-red pl-3">{grade}</h3>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
            {masterGroups[grade].map((student) => (
              <div class="bg-white rounded-lg border border-gray-200 p-4 hover:shadow-md transition-shadow flex items-start gap-4">
                <img
                  src={student.image}
                  alt={student.name}
                  class="w-14 h-14 rounded-full object-cover shrink-0 border-2 border-gray-100"
                />
                <div class="min-w-0">
                  <h4 class="font-semibold text-gray-900">{student.name}</h4>
                  <p class="text-xs text-gray-500 mt-0.5">{student.grade}</p>
                  <p class="text-sm text-gray-600 mt-1 leading-snug">{student.research}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </section>

  </div>
</Layout>
